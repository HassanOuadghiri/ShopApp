<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Material 3, NoActionBar since we use our own Toolbar) -->
    <style name="Theme.ShopApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (Allegro-like Orange) -->
        <item name="colorPrimary">#FF5A00</item>
        <item name="colorPrimaryVariant">#E04F00</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">#80CBC4</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
</resources>